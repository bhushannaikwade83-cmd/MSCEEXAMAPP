[
  {
    "corsRuleName": "allowWebAppUploadDownload",
    "allowedOrigins": ["*"],
    "allowedOperations": [
      "b2_download_file_by_name",
      "b2_download_file_by_id",
      "b2_upload_file",
      "b2_upload_part"
    ],
    "allowedHeaders": ["*"],
    "exposeHeaders": ["x-bz-content-sha1"],
    "maxAgeSeconds": 3600
  }
]
